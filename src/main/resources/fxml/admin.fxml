<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.chart.CategoryAxis?>
<?import javafx.scene.chart.LineChart?>
<?import javafx.scene.chart.NumberAxis?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<BorderPane stylesheets="@/css/styles.css" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.budgetfit.controllers.AdminController">
    <!-- Navigation Bar -->
    <top>
        <HBox alignment="CENTER_LEFT" spacing="20" styleClass="nav-header">
            <Label text="BudgetFit Console" style="-fx-font-size: 24px; -fx-font-weight: 800; -fx-text-fill: #3e6560;" />
            <Region HBox.hgrow="ALWAYS" />
            <Label text="Administrator" style="-fx-font-size: 15px; -fx-font-weight: 600; -fx-text-fill: #7d5546;" />
            <Button onAction="#handleLogout" styleClass="btn-logout" text="Logout" />
        </HBox>
    </top>

    <!-- Main Content -->
    <center>
        <VBox spacing="24" style="-fx-padding: 32;">
            <!-- Metrics Cards -->
            <HBox spacing="24">
                <VBox alignment="CENTER" prefHeight="120" styleClass="card" HBox.hgrow="ALWAYS" style="-fx-padding: 20;">
                    <Label style="-fx-font-size: 12px; -fx-font-weight: 700; -fx-text-fill: #717977;" text="TOTAL USERS" />
                    <Label fx:id="totalUsersLabel" style="-fx-font-size: 36px; -fx-font-weight: 700; -fx-text-fill: #1b1c1c;" text="0" />
                </VBox>
                <VBox alignment="CENTER" prefHeight="120" styleClass="card" HBox.hgrow="ALWAYS" style="-fx-padding: 20;">
                    <Label style="-fx-font-size: 12px; -fx-font-weight: 700; -fx-text-fill: #717977;" text="ACTIVE TODAY" />
                    <Label fx:id="activeUsersLabel" style="-fx-font-size: 36px; -fx-font-weight: 700; -fx-text-fill: #3e6560;" text="0" />
                </VBox>
                <VBox alignment="CENTER" prefHeight="120" styleClass="card" HBox.hgrow="ALWAYS" style="-fx-padding: 20;">
                    <Label style="-fx-font-size: 12px; -fx-font-weight: 700; -fx-text-fill: #717977;" text="CHURNED USERS" />
                    <Label fx:id="churnUsersLabel" style="-fx-font-size: 36px; -fx-font-weight: 700; -fx-text-fill: #ba1a1a;" text="0" />
                </VBox>
            </HBox>
            
            <HBox spacing="24" VBox.vgrow="ALWAYS">
                <!-- User Activity Trends -->
                <VBox prefWidth="400" styleClass="card" HBox.hgrow="ALWAYS">
                    <VBox styleClass="header-panel">
                        <Label text="USER ACTIVITY TRENDS" styleClass="header-title" />
                    </VBox>
                    <VBox style="-fx-padding: 20;" VBox.vgrow="ALWAYS">
                        <LineChart fx:id="activityChart" legendVisible="false" VBox.vgrow="ALWAYS">
                            <xAxis><CategoryAxis side="BOTTOM" /></xAxis>
                            <yAxis><NumberAxis side="LEFT" /></yAxis>
                        </LineChart>
                    </VBox>
                </VBox>

                <!-- User Management Table -->
                <VBox prefWidth="500" styleClass="card" HBox.hgrow="ALWAYS">
                    <VBox styleClass="header-panel">
                        <Label text="USER MANAGEMENT" styleClass="header-title" />
                    </VBox>
                    <TableView fx:id="userTable" style="-fx-padding: 2;" VBox.vgrow="ALWAYS">
                        <columns>
                            <TableColumn fx:id="userIdCol" prefWidth="50" text="ID" />
                            <TableColumn fx:id="usernameCol" prefWidth="120" text="USERNAME" />
                            <TableColumn fx:id="roleCol" prefWidth="80" text="ROLE" />
                            <TableColumn fx:id="lastActiveCol" prefWidth="140" text="LAST ACTIVE" />
                            <TableColumn fx:id="userActionCol" maxWidth="50" minWidth="50" prefWidth="50" sortable="false" style="-fx-alignment: CENTER;" text="" />
                        </columns>
                        <columnResizePolicy><TableView fx:constant="CONSTRAINED_RESIZE_POLICY" /></columnResizePolicy>
                    </TableView>
                </VBox>
            </HBox>
        </VBox>
    </center>
</BorderPane>
