<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.chart.BarChart?>
<?import javafx.scene.chart.CategoryAxis?>
<?import javafx.scene.chart.NumberAxis?>
<?import javafx.scene.chart.PieChart?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.CheckBox?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ProgressBar?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.control.Tooltip?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.ColumnConstraints?>
<?import javafx.scene.layout.FlowPane?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.shape.Circle?>
<?import javafx.scene.shape.SVGPath?>

<BorderPane fx:id="mainPane" stylesheets="@/css/styles.css" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.budgetfit.controllers.DashboardController">
    
    <!-- LEFT SIDEBAR NAVIGATION -->
    <left>
        <VBox fx:id="leftSidebar" spacing="16" styleClass="sidebar" prefWidth="88">
            <!-- HEADER: BRAND LOGO & TOGGLE BUTTON -->
            <HBox alignment="CENTER_LEFT" spacing="12">
                <VBox alignment="CENTER" styleClass="brand-box">
                    <Label text="BF" styleClass="brand-box-text">
                        <tooltip><Tooltip text="BudgetFit Platform" /></tooltip>
                    </Label>
                </VBox>
                <Label fx:id="brandTitle" text="BudgetFit" styleClass="wordmark-title" visible="false" managed="false" />
                <Region HBox.hgrow="ALWAYS" />
                <Button onAction="#handleToggleMenu" styleClass="btn-toggle-menu">
                    <graphic>
                        <SVGPath content="M3 18H21V16H3V18ZM3 13H21V11H3V13ZM3 6V8H21V6H3Z" styleClass="toggle-icon" />
                    </graphic>
                    <tooltip><Tooltip text="Toggle Sidebar" /></tooltip>
                </Button>
            </HBox>

            <Region prefHeight="16" />

            <!-- NAVIGATION BUTTONS (ICON + OPTIONAL LABEL) -->
            <Button fx:id="navAtmBtn" onAction="#showAtmView" styleClass="nav-btn">
                <graphic>
                    <HBox alignment="CENTER_LEFT" spacing="16">
                        <SVGPath content="M21 18V19C21 20.1 20.1 21 19 21H5C3.9 21 3 20.1 3 19V5C3 3.9 3.9 3 5 3H19C20.1 3 21 3.9 21 5V6H12C10.9 6 10 6.9 10 8V16C10 17.1 10.9 18 12 18H21ZM12 16H22V8H12V16ZM16 13.5C15.17 13.5 14.5 12.83 14.5 12C14.5 11.17 15.17 10.5 16 10.5C16.83 10.5 17.5 11.17 17.5 12C17.5 12.83 16.83 13.5 16 13.5Z" styleClass="nav-icon" />
                        <Label fx:id="lblAtm" text="ATM &amp; Banking" styleClass="nav-label" visible="false" managed="false" />
                    </HBox>
                </graphic>
                <tooltip><Tooltip text="ATM &amp; Banking" /></tooltip>
            </Button>

            <Button fx:id="navBudgetBtn" onAction="#showBudgetView" styleClass="nav-btn, nav-btn-active">
                <graphic>
                    <HBox alignment="CENTER_LEFT" spacing="16">
                        <SVGPath content="M3 3H11V11H3V3ZM13 3H21V11H13V3ZM3 13H11V21H3V13ZM13 13H21V21H13V13Z" styleClass="nav-icon" />
                        <Label fx:id="lblBudget" text="Budgeting &amp; Tracking" styleClass="nav-label" visible="false" managed="false" />
                    </HBox>
                </graphic>
                <tooltip><Tooltip text="Budgeting &amp; Tracking" /></tooltip>
            </Button>

            <Button fx:id="navSavingsBtn" onAction="#showSavingsView" styleClass="nav-btn">
                <graphic>
                    <HBox alignment="CENTER_LEFT" spacing="16">
                        <SVGPath content="M12 1L3 5V11C3 16.55 6.84 21.74 12 23C17.16 21.74 21 16.55 21 11V5L12 1ZM12 10.99H19C18.47 14.94 15.75 18.41 12 19.93V10.99H5V6.3L12 3.19V10.99Z" styleClass="nav-icon" />
                        <Label fx:id="lblSavings" text="Savings Goals" styleClass="nav-label" visible="false" managed="false" />
                    </HBox>
                </graphic>
                <tooltip><Tooltip text="Savings Goals" /></tooltip>
            </Button>

            <Button fx:id="navInvestmentsBtn" onAction="#showInvestmentsView" styleClass="nav-btn">
                <graphic>
                    <HBox alignment="CENTER_LEFT" spacing="16">
                        <SVGPath content="M16 6L18.29 8.29L13.41 13.17L9.41 9.17L2 16.59L3.41 18L9.41 12L13.41 16L19.71 9.71L22 12V6H16Z" styleClass="nav-icon" />
                        <Label fx:id="lblInvestments" text="Investment Simulator" styleClass="nav-label" visible="false" managed="false" />
                    </HBox>
                </graphic>
                <tooltip><Tooltip text="Investment Simulator" /></tooltip>
            </Button>

            <Button fx:id="navLedgerBtn" onAction="#showLedgerView" styleClass="nav-btn">
                <graphic>
                    <HBox alignment="CENTER_LEFT" spacing="16">
                        <SVGPath content="M14 2H6C4.9 2 4 2.9 4 4V20C4 21.1 4.9 22 6 22H18C19.1 22 20 21.1 20 20V8L14 2ZM18 20H6V4H13V9H18V20ZM8 12H16V14H8V12ZM8 16H16V18H8V16Z" styleClass="nav-icon" />
                        <Label fx:id="lblLedger" text="Transaction Ledger" styleClass="nav-label" visible="false" managed="false" />
                    </HBox>
                </graphic>
                <tooltip><Tooltip text="Transaction Ledger" /></tooltip>
            </Button>

            <Region VBox.vgrow="ALWAYS" />

            <!-- BOTTOM CONTROLS -->
            <VBox spacing="16" alignment="CENTER_LEFT" style="-fx-padding: 20 0 0 0; -fx-border-color: #334155; -fx-border-width: 1 0 0 0;">
                <HBox alignment="CENTER_LEFT" spacing="16">
                    <CheckBox fx:id="darkModeBox" onAction="#handleThemeToggle" styleClass="theme-checkbox">
                        <tooltip><Tooltip text="Toggle Dark Mode" /></tooltip>
                    </CheckBox>
                    <Label fx:id="lblTheme" text="Dark Mode" styleClass="nav-label" visible="false" managed="false" />
                </HBox>
                <Button onAction="#handleLogout" styleClass="btn-logout-collapsed">
                    <graphic>
                        <HBox alignment="CENTER_LEFT" spacing="16">
                            <SVGPath content="M17 7L15.59 8.41L18.17 11H8V13H18.17L15.59 15.59L17 17L22 12L17 7ZM4 5H12V3H4C2.9 3 2 3.9 2 5V19C2 20.1 2.9 21 4 21H12V19H4V5Z" styleClass="logout-icon" />
                            <Label fx:id="lblLogout" text="Logout" styleClass="nav-label" visible="false" managed="false" />
                        </HBox>
                    </graphic>
                    <tooltip><Tooltip text="Logout" /></tooltip>
                </Button>
                <!-- Hidden welcome label to satisfy controller injection without breaking layout -->
                <Label fx:id="welcomeLabel" visible="false" managed="false" />
            </VBox>
        </VBox>
    </left>

    <!-- TOP HEADER BAR -->
    <top>
        <HBox alignment="CENTER_LEFT" spacing="16" styleClass="controls-bar">
            <!-- Left: View Title & Date -->
            <HBox alignment="CENTER_LEFT" spacing="12">
                <Label fx:id="viewTitleLabel" text="Budgeting &amp; Tracking" styleClass="view-title" />
                <Label fx:id="headerDateLabel" text="» May 19, 2026" styleClass="header-date" />
            </HBox>
            
            <Region HBox.hgrow="ALWAYS" />

            <!-- Right side elements: Search, Filters, Actions, Notifications, Profile -->
            <HBox alignment="CENTER_LEFT" spacing="12">
                <!-- Search Box Container -->
                <HBox alignment="CENTER_LEFT" styleClass="search-box-container">
                    <SVGPath content="M15.5 14h-.79l-.28-.27C15.41 12.59 16 11.11 16 9.5 16 5.91 13.09 3 9.5 3S3 5.91 3 9.5 5.91 16 9.5 16c1.61 0 3.09-.59 4.23-1.57l.27.28v.79l5 4.99L20.49 19l-4.99-5zm-6 0C7.01 14 5 11.99 5 9.5S7.01 5 9.5 5 14 7.01 14 9.5 11.99 14 9.5 14z" styleClass="search-icon-svg" />
                    <TextField fx:id="searchField" promptText="Search here..." styleClass="search-field-premium" />
                </HBox>

                <!-- Month Selector Pill -->
                <ComboBox fx:id="monthSelector" prefWidth="120" promptText="Select Month" styleClass="combo-box-pill" />

                <!-- Action Button: Sync Recurring -->
                <Button onAction="#handleSyncRecurring" styleClass="btn-icon-header">
                    <graphic>
                        <SVGPath content="M12 4V1L8 5l4 4V6c3.31 0 6 2.69 6 6 0 1.01-.25 1.97-.7 2.8l1.46 1.46C19.54 15.03 20 13.57 20 12c0-4.42-3.58-8-8-8zm0 14c-3.31 0-6-2.69-6-6 0-1.01.25-1.97.7-2.8L5.24 7.74C4.46 8.97 4 10.43 4 12c0 4.42 3.58 8 8 8v3l4-4-4-4v3z" styleClass="header-action-svg" />
                    </graphic>
                    <tooltip><Tooltip text="Sync Recurring Transactions" /></tooltip>
                </Button>

                <!-- Action Button: View Trends -->
                <Button onAction="#handleViewTrends" styleClass="btn-icon-header">
                    <graphic>
                        <SVGPath content="M16 6l2.29 2.29-4.88 4.88-4-4L2 16.59 3.41 18l6-6 4 4 6.3-6.29L22 12V6z" styleClass="header-action-svg" />
                    </graphic>
                    <tooltip><Tooltip text="View Trends Analysis" /></tooltip>
                </Button>

                <!-- Currency Selector Pill -->
                <ComboBox fx:id="currencySelector" prefWidth="80" styleClass="combo-box-pill" />

                <!-- Action Button: Export CSV -->
                <Button onAction="#handleExportCsv" styleClass="btn-icon-header">
                    <graphic>
                        <SVGPath content="M19.35 10.04C18.67 6.59 15.64 4 12 4 9.11 4 6.6 5.64 5.35 8.04 2.34 8.36 0 10.91 0 14c0 3.31 2.69 6 6 6h13c2.76 0 5-2.24 5-5 0-2.64-2.05-4.78-4.65-4.96zM17 13l-5 5-5-5h3V9h4v4h3z" styleClass="header-action-svg" />
                    </graphic>
                    <tooltip><Tooltip text="Export current view to CSV" /></tooltip>
                </Button>

                <Region prefWidth="4" />

                <!-- Notification Bell Badge Stack -->
                <StackPane styleClass="notification-container">
                    <Button styleClass="btn-icon-notification">
                        <graphic>
                            <SVGPath content="M12 22c1.1 0 2-.9 2-2h-4c0 1.1.89 2 2 2zm6-6v-5c0-3.07-1.64-5.64-4.5-6.32V4c0-.83-.67-1.5-1.5-1.5s-1.5.67-1.5 1.5v.68C7.63 5.36 6 7.92 6 11v5l-2 2v1h16v-1l-2-2z" styleClass="notification-bell-svg" />
                        </graphic>
                        <tooltip><Tooltip text="System Notifications" /></tooltip>
                    </Button>
                    <Circle radius="4" fill="#10b981" StackPane.alignment="TOP_RIGHT" styleClass="notification-badge" />
                </StackPane>

                <Region prefWidth="4" />

                <!-- Profile Initials Avatar -->
                <HBox alignment="CENTER" styleClass="profile-badge-container">
                    <VBox alignment="CENTER" styleClass="avatar-circle">
                        <Label fx:id="avatarLabel" text="U" styleClass="avatar-text" />
                    </VBox>
                </HBox>
            </HBox>
        </HBox>
    </top>

    <!-- CENTER CONTENT AREA -->
    <center>
        <StackPane fx:id="contentArea" style="-fx-background-color: #f8fafc;">
            
            <!-- 1. BUDGETING VIEW -->
            <ScrollPane fx:id="budgetView" fitToWidth="true" fitToHeight="true" hbarPolicy="NEVER" styleClass="scroll-pane">
                <content>
                    <VBox spacing="24" style="-fx-padding: 30 35;">
                        <!-- Summary Bento Box -->
                        <HBox spacing="24" alignment="CENTER">
                            <VBox styleClass="bento-stat-card" HBox.hgrow="ALWAYS">
                                <Label text="Monthly Income" styleClass="bento-stat-label" />
                                <Label fx:id="statTotalIncome" text="\$0.00" styleClass="bento-stat-value" />
                                <Label text="Target: \$5,000" styleClass="bento-stat-sub" />
                            </VBox>
                            <VBox styleClass="bento-stat-card" HBox.hgrow="ALWAYS">
                                <Label text="Burn Rate" styleClass="bento-stat-label" />
                                <Label fx:id="statBurnRate" text="\$0.00 / day" styleClass="bento-stat-value" />
                                <Label fx:id="statBurnRateSub" text="Healthy" styleClass="bento-stat-sub" />
                            </VBox>
                            <VBox styleClass="bento-stat-card" HBox.hgrow="ALWAYS">
                                <Label text="Savings Rate" styleClass="bento-stat-label" />
                                <Label fx:id="statSavingsRate" text="0%" styleClass="bento-stat-value" />
                                <Label text="Goal: 20%" styleClass="bento-stat-sub" />
                            </VBox>
                        </HBox>

                        <GridPane hgap="24.0" vgap="24.0">
                            <!-- Row 0: Top Cards (Pie Charts) -->
                            <VBox styleClass="card" GridPane.columnIndex="0" GridPane.rowIndex="0" maxWidth="Infinity">
                                <VBox styleClass="header-panel"><Label text="AMOUNT LEFT TO SPEND" styleClass="header-title" /></VBox>
                                <VBox alignment="CENTER" spacing="16" style="-fx-padding: 20;">
                                    <HBox alignment="CENTER" spacing="10">
                                        <Label text="Monthly Income:" style="-fx-font-size: 14px; -fx-font-weight: 700; -fx-text-fill: #64748b;" />
                                        <TextField fx:id="monthlyIncomeField" prefWidth="125" style="-fx-font-size: 15px; -fx-font-weight: 800; -fx-alignment: CENTER; -fx-background-radius: 8; -fx-border-color: #cbd5e1; -fx-border-radius: 8; -fx-padding: 6 10;" text="5000.00" />
                                    </HBox>
                                    <StackPane prefHeight="220">
                                        <PieChart fx:id="budgetPieChart" labelsVisible="false" legendVisible="false" />
                                        <StackPane mouseTransparent="true" prefWidth="120" prefHeight="120" maxWidth="120" maxHeight="120" style="-fx-background-color: white; -fx-background-radius: 1000; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.08), 15, 0, 0, 0);">
                                            <VBox alignment="CENTER" spacing="2">
                                                <Label text="LEFT TO SPEND" style="-fx-font-size: 10px; -fx-font-weight: 800; -fx-text-fill: #64748b;" />
                                                <Label fx:id="amountLeftLabel" style="-fx-font-size: 20px; -fx-font-weight: 900; -fx-text-fill: #10b981;" text="0.00" />
                                            </VBox>
                                        </StackPane>
                                    </StackPane>
                                </VBox>
                            </VBox>

                            <VBox styleClass="card" GridPane.columnIndex="1" GridPane.rowIndex="0" maxWidth="Infinity">
                                <VBox styleClass="header-panel"><Label text="ALLOCATION SUMMARY" styleClass="header-title" /></VBox>
                                <StackPane style="-fx-padding: 20;"><PieChart fx:id="allocationPieChart" labelsVisible="false" legendSide="BOTTOM" prefHeight="265" /></StackPane>
                            </VBox>

                            <VBox styleClass="card" GridPane.columnIndex="2" GridPane.rowIndex="0" maxWidth="Infinity">
                                <VBox styleClass="header-panel"><Label text="QUICK SAVINGS GOALS" styleClass="header-title" /></VBox>
                                <ScrollPane fitToWidth="true" hbarPolicy="NEVER" styleClass="sub-scroll-pane" style="-fx-pref-height: 265;">
                                    <VBox fx:id="goalsContainer" spacing="15" style="-fx-padding: 20;" />
                                </ScrollPane>
                            </VBox>

                            <!-- Row 1: Income, Expenses, Bills -->
                            <VBox styleClass="card" GridPane.columnIndex="0" GridPane.rowIndex="1" maxWidth="Infinity">
                                <VBox styleClass="header-panel"><Label text="INCOME" styleClass="header-title" /></VBox>
                                <TableView fx:id="incomeTable" editable="true" prefHeight="300" style="-fx-padding: 2;" VBox.vgrow="ALWAYS">
                                    <columns>
                                        <TableColumn fx:id="incCatCol" prefWidth="120" text="CATEGORY" />
                                        <TableColumn fx:id="incBudgetCol" prefWidth="80" style="-fx-alignment: CENTER-RIGHT;" text="PLANNED" />
                                        <TableColumn fx:id="incActualCol" prefWidth="80" style="-fx-alignment: CENTER-RIGHT;" text="ACTUAL" />
                                        <TableColumn fx:id="incRecCol" maxWidth="35" minWidth="35" prefWidth="35" sortable="false" style="-fx-alignment: CENTER;" text="R" />
                                        <TableColumn fx:id="incActionCol" maxWidth="35" minWidth="35" prefWidth="35" sortable="false" style="-fx-alignment: CENTER;" text="" />
                                    </columns>
                                    <columnResizePolicy><TableView fx:constant="CONSTRAINED_RESIZE_POLICY" /></columnResizePolicy>
                                </TableView>
                                <VBox spacing="4" style="-fx-padding: 0 12 8 12;"><ProgressBar fx:id="incProgressBar" prefWidth="1000" progress="0.0" styleClass="budget-progress" /></VBox>
                                <HBox alignment="CENTER_RIGHT" spacing="5" style="-fx-padding: 12 16; -fx-background-color: #f8fafc; -fx-border-color: #e2e8f0; -fx-border-width: 1 0 0 0; -fx-background-radius: 0 0 15 15;">
                                    <Label style="-fx-font-weight: 800; -fx-font-size: 12px; -fx-text-fill: #64748b;" text="TOTAL" />
                                    <Region HBox.hgrow="ALWAYS" />
                                    <Label fx:id="incTotalBudgetLabel" prefWidth="80" style="-fx-font-weight: 800; -fx-font-size: 13px; -fx-text-fill: #0f172a; -fx-alignment: CENTER-RIGHT;" text="0.00" />
                                    <Label fx:id="incTotalActualLabel" prefWidth="80" style="-fx-font-weight: 800; -fx-font-size: 13px; -fx-text-fill: #10b981; -fx-alignment: CENTER-RIGHT;" text="0.00" />
                                    <Region prefWidth="70" />
                                </HBox>
                            </VBox>

                            <VBox styleClass="card" GridPane.columnIndex="1" GridPane.rowIndex="1" maxWidth="Infinity">
                                <VBox styleClass="header-panel"><Label text="EXPENSE" styleClass="header-title" /></VBox>
                                <TableView fx:id="expenseTable" editable="true" prefHeight="300" style="-fx-padding: 2;" VBox.vgrow="ALWAYS">
                                    <columns>
                                        <TableColumn fx:id="expCatCol" prefWidth="120" text="CATEGORY" />
                                        <TableColumn fx:id="expBudgetCol" prefWidth="80" style="-fx-alignment: CENTER-RIGHT;" text="PLANNED" />
                                        <TableColumn fx:id="expActualCol" prefWidth="80" style="-fx-alignment: CENTER-RIGHT;" text="ACTUAL" />
                                        <TableColumn fx:id="expRecCol" maxWidth="35" minWidth="35" prefWidth="35" sortable="false" style="-fx-alignment: CENTER;" text="R" />
                                        <TableColumn fx:id="expActionCol" maxWidth="35" minWidth="35" prefWidth="35" sortable="false" style="-fx-alignment: CENTER;" text="" />
                                    </columns>
                                    <columnResizePolicy><TableView fx:constant="CONSTRAINED_RESIZE_POLICY" /></columnResizePolicy>
                                </TableView>
                                <VBox spacing="4" style="-fx-padding: 0 12 8 12;"><ProgressBar fx:id="expProgressBar" prefWidth="1000" progress="0.0" styleClass="budget-progress" /></VBox>
                                <HBox alignment="CENTER_RIGHT" spacing="5" style="-fx-padding: 12 16; -fx-background-color: #f8fafc; -fx-border-color: #e2e8f0; -fx-border-width: 1 0 0 0; -fx-background-radius: 0 0 15 15;">
                                    <Label style="-fx-font-weight: 800; -fx-font-size: 12px; -fx-text-fill: #64748b;" text="TOTAL" />
                                    <Region HBox.hgrow="ALWAYS" />
                                    <Label fx:id="expTotalBudgetLabel" prefWidth="80" style="-fx-font-weight: 800; -fx-font-size: 13px; -fx-text-fill: #0f172a; -fx-alignment: CENTER-RIGHT;" text="0.00" />
                                    <Label fx:id="expTotalActualLabel" prefWidth="80" style="-fx-font-weight: 800; -fx-font-size: 13px; -fx-text-fill: #10b981; -fx-alignment: CENTER-RIGHT;" text="0.00" />
                                    <Region prefWidth="70" />
                                </HBox>
                            </VBox>

                            <VBox styleClass="card" GridPane.columnIndex="2" GridPane.rowIndex="1" maxWidth="Infinity">
                                <VBox styleClass="header-panel"><Label text="BILLS" styleClass="header-title" /></VBox>
                                <TableView fx:id="billTable" editable="true" prefHeight="300" style="-fx-padding: 2;" VBox.vgrow="ALWAYS">
                                    <columns>
                                        <TableColumn fx:id="billCatCol" prefWidth="100" text="CATEGORY" />
                                        <TableColumn fx:id="billBudgetCol" prefWidth="70" style="-fx-alignment: CENTER-RIGHT;" text="PLANNED" />
                                        <TableColumn fx:id="billActualCol" prefWidth="70" style="-fx-alignment: CENTER-RIGHT;" text="ACTUAL" />
                                        <TableColumn fx:id="billPaidCol" maxWidth="45" minWidth="45" prefWidth="45" sortable="false" style="-fx-alignment: CENTER;" text="PAID?" />
                                        <TableColumn fx:id="billRecCol" maxWidth="35" minWidth="35" prefWidth="35" sortable="false" style="-fx-alignment: CENTER;" text="R" />
                                        <TableColumn fx:id="billActionCol" maxWidth="35" minWidth="35" prefWidth="35" sortable="false" style="-fx-alignment: CENTER;" text="" />
                                    </columns>
                                    <columnResizePolicy><TableView fx:constant="CONSTRAINED_RESIZE_POLICY" /></columnResizePolicy>
                                </TableView>
                                <VBox spacing="4" style="-fx-padding: 0 12 8 12;"><ProgressBar fx:id="billProgressBar" prefWidth="1000" progress="0.0" styleClass="budget-progress" /></VBox>
                                <HBox alignment="CENTER_RIGHT" spacing="5" style="-fx-padding: 12 16; -fx-background-color: #f8fafc; -fx-border-color: #e2e8f0; -fx-border-width: 1 0 0 0; -fx-background-radius: 0 0 15 15;">
                                    <Label style="-fx-font-weight: 800; -fx-font-size: 12px; -fx-text-fill: #64748b;" text="TOTAL" />
                                    <Region HBox.hgrow="ALWAYS" />
                                    <Label fx:id="billTotalBudgetLabel" prefWidth="70" style="-fx-font-weight: 800; -fx-font-size: 13px; -fx-text-fill: #0f172a; -fx-alignment: CENTER-RIGHT;" text="0.00" />
                                    <Label fx:id="billTotalActualLabel" prefWidth="70" style="-fx-font-weight: 800; -fx-font-size: 13px; -fx-text-fill: #10b981; -fx-alignment: CENTER-RIGHT;" text="0.00" />
                                    <Region prefWidth="115" />
                                </HBox>
                            </VBox>

                            <!-- Row 2: Savings, Debt -->
                            <VBox styleClass="card" GridPane.columnIndex="0" GridPane.rowIndex="2" maxWidth="Infinity">
                                <VBox styleClass="header-panel"><Label text="SAVINGS" styleClass="header-title" /></VBox>
                                <TableView fx:id="savingsTable" editable="true" prefHeight="300" style="-fx-padding: 2;" VBox.vgrow="ALWAYS">
                                    <columns>
                                        <TableColumn fx:id="savCatCol" prefWidth="120" text="CATEGORY" />
                                        <TableColumn fx:id="savBudgetCol" prefWidth="80" style="-fx-alignment: CENTER-RIGHT;" text="PLANNED" />
                                        <TableColumn fx:id="savActualCol" prefWidth="80" style="-fx-alignment: CENTER-RIGHT;" text="ACTUAL" />
                                        <TableColumn fx:id="savRecCol" maxWidth="35" minWidth="35" prefWidth="35" sortable="false" style="-fx-alignment: CENTER;" text="R" />
                                        <TableColumn fx:id="savActionCol" maxWidth="35" minWidth="35" prefWidth="35" sortable="false" style="-fx-alignment: CENTER;" text="" />
                                    </columns>
                                    <columnResizePolicy><TableView fx:constant="CONSTRAINED_RESIZE_POLICY" /></columnResizePolicy>
                                </TableView>
                                <VBox spacing="4" style="-fx-padding: 0 12 8 12;"><ProgressBar fx:id="savProgressBar" prefWidth="1000" progress="0.0" styleClass="budget-progress" /></VBox>
                                <HBox alignment="CENTER_RIGHT" spacing="5" style="-fx-padding: 12 16; -fx-background-color: #f8fafc; -fx-border-color: #e2e8f0; -fx-border-width: 1 0 0 0; -fx-background-radius: 0 0 15 15;">
                                    <Label style="-fx-font-weight: 800; -fx-font-size: 12px; -fx-text-fill: #64748b;" text="TOTAL" />
                                    <Region HBox.hgrow="ALWAYS" />
                                    <Label fx:id="savTotalBudgetLabel" prefWidth="80" style="-fx-font-weight: 800; -fx-font-size: 13px; -fx-text-fill: #0f172a; -fx-alignment: CENTER-RIGHT;" text="0.00" />
                                    <Label fx:id="savTotalActualLabel" prefWidth="80" style="-fx-font-weight: 800; -fx-font-size: 13px; -fx-text-fill: #10b981; -fx-alignment: CENTER-RIGHT;" text="0.00" />
                                    <Region prefWidth="70" />
                                </HBox>
                            </VBox>

                            <VBox styleClass="card" GridPane.columnIndex="1" GridPane.rowIndex="2" GridPane.columnSpan="2" maxWidth="Infinity">
                                <VBox styleClass="header-panel"><Label text="DEBT" styleClass="header-title" /></VBox>
                                <TableView fx:id="debtTable" editable="true" prefHeight="300" style="-fx-padding: 2;" VBox.vgrow="ALWAYS">
                                    <columns>
                                        <TableColumn fx:id="debtCatCol" prefWidth="120" text="CATEGORY" />
                                        <TableColumn fx:id="debtBudgetCol" prefWidth="80" style="-fx-alignment: CENTER-RIGHT;" text="PLANNED" />
                                        <TableColumn fx:id="debtActualCol" prefWidth="80" style="-fx-alignment: CENTER-RIGHT;" text="ACTUAL" />
                                        <TableColumn fx:id="debtRecCol" maxWidth="35" minWidth="35" prefWidth="35" sortable="false" style="-fx-alignment: CENTER;" text="R" />
                                        <TableColumn fx:id="debtActionCol" maxWidth="35" minWidth="35" prefWidth="35" sortable="false" style="-fx-alignment: CENTER;" text="" />
                                    </columns>
                                    <columnResizePolicy><TableView fx:constant="CONSTRAINED_RESIZE_POLICY" /></columnResizePolicy>
                                </TableView>
                                <VBox spacing="4" style="-fx-padding: 0 12 8 12;"><ProgressBar fx:id="debtProgressBar" prefWidth="1000" progress="0.0" styleClass="budget-progress" /></VBox>
                                <HBox alignment="CENTER_RIGHT" spacing="5" style="-fx-padding: 12 16; -fx-background-color: #f8fafc; -fx-border-color: #e2e8f0; -fx-border-width: 1 0 0 0; -fx-background-radius: 0 0 15 15;">
                                    <Label style="-fx-font-weight: 800; -fx-font-size: 12px; -fx-text-fill: #64748b;" text="TOTAL" />
                                    <Region HBox.hgrow="ALWAYS" />
                                    <Label fx:id="debtTotalBudgetLabel" prefWidth="80" style="-fx-font-weight: 800; -fx-font-size: 13px; -fx-text-fill: #0f172a; -fx-alignment: CENTER-RIGHT;" text="0.00" />
                                    <Label fx:id="debtTotalActualLabel" prefWidth="80" style="-fx-font-weight: 800; -fx-font-size: 13px; -fx-text-fill: #10b981; -fx-alignment: CENTER-RIGHT;" text="0.00" />
                                    <Region prefWidth="70" />
                                </HBox>
                            </VBox>
                            <columnConstraints>
                                <ColumnConstraints percentWidth="33.3" />
                                <ColumnConstraints percentWidth="33.3" />
                                <ColumnConstraints percentWidth="33.3" />
                            </columnConstraints>
                        </GridPane>
                    </VBox>
                </content>
            </ScrollPane>

            <!-- 2. SAVINGS GOALS FULL VIEW (WRAPPED IN SCROLLPANE) -->
            <ScrollPane fx:id="savingsView" fitToWidth="true" fitToHeight="true" hbarPolicy="NEVER" styleClass="scroll-pane" visible="false">
                <content>
                    <VBox spacing="30" style="-fx-padding: 30 35;">
                        <!-- HERO BANNER: Wealth in Motion -->
                        <HBox styleClass="hero-card" alignment="CENTER_LEFT" spacing="24">
                            <VBox spacing="8" HBox.hgrow="ALWAYS">
                                <Label text="Wealth in Motion" styleClass="hero-title" />
                                <Label text="Your capital, compounding quietly toward future wins." styleClass="hero-subtitle" />
                                <HBox spacing="12" alignment="BASELINE_LEFT" style="-fx-padding: 12 0 4 0;">
                                    <Label fx:id="savHeroTotalLabel" text="₦0.00" styleClass="hero-amount" />
                                    <Label fx:id="savHeroTargetLabel" text="of ₦0.00 target" styleClass="hero-target" />
                                </HBox>
                                <ProgressBar fx:id="savHeroProgressBar" prefWidth="600" prefHeight="12" progress="0.0" styleClass="budget-progress" />
                            </VBox>
                            <VBox spacing="12" alignment="CENTER_RIGHT">
                                <Button text="+ New Goal" onAction="#handleAddGoal" styleClass="btn-outline" />
                                <Button text="+ Add Savings" onAction="#handleQuickContribute" styleClass="btn-primary" />
                            </VBox>
                        </HBox>

                        <!-- SAVINGS BUCKETS SECTION -->
                        <VBox spacing="16">
                            <Label text="Savings Buckets" styleClass="section-title" />
                            <!-- Using FlowPane so cards wrap into beautiful grid -->
                            <FlowPane fx:id="fullGoalsContainer" hgap="20" vgap="20" />
                        </VBox>

                        <!-- BOTTOM SPLIT SECTION: Growth Over Time / Recent Activity -->
                        <HBox spacing="24">
                            <VBox styleClass="card" HBox.hgrow="ALWAYS" spacing="16" style="-fx-padding: 24;">
                                <VBox spacing="4">
                                    <Label text="Growth Over Time" styleClass="card-title" />
                                    <Label text="Monitor monthly growth to keep your financial goals on track." styleClass="card-subtitle" />
                                </VBox>
                                <StackPane prefHeight="240">
                                    <BarChart fx:id="savGrowthChart" legendVisible="false">
                                        <xAxis><CategoryAxis /></xAxis>
                                        <yAxis><NumberAxis /></yAxis>
                                    </BarChart>
                                </StackPane>
                            </VBox>
                            <VBox styleClass="card" prefWidth="380" spacing="16" style="-fx-padding: 24;">
                                <Label text="Recent Activity" styleClass="card-title" />
                                <ScrollPane fitToWidth="true" hbarPolicy="NEVER" styleClass="sub-scroll-pane" style="-fx-pref-height: 240;">
                                    <VBox fx:id="savActivityContainer" spacing="12" />
                                </ScrollPane>
                            </VBox>
                        </HBox>
                    </VBox>
                </content>
            </ScrollPane>

            <!-- 3. TRANSACTION LEDGER FULL VIEW (WRAPPED IN SCROLLPANE) -->
            <ScrollPane fx:id="ledgerView" fitToWidth="true" fitToHeight="true" hbarPolicy="NEVER" styleClass="scroll-pane" visible="false">
                <content>
                    <VBox spacing="24" style="-fx-padding: 30 35;">
                        <!-- TOP TITLE & TABS -->
                        <VBox spacing="16">
                            <Label text="Transactions" styleClass="view-header-title" />
                            <HBox spacing="24" alignment="CENTER_LEFT">
                                <Label fx:id="tabAll" text="All" onMouseClicked="#handleLedgerTab" styleClass="tab-lbl-active" />
                                <Label fx:id="tabIncome" text="Income" onMouseClicked="#handleLedgerTab" styleClass="tab-lbl" />
                                <Label fx:id="tabExpenses" text="Expenses" onMouseClicked="#handleLedgerTab" styleClass="tab-lbl" />
                                <Label fx:id="tabBills" text="Bills" onMouseClicked="#handleLedgerTab" styleClass="tab-lbl" />
                                <Label fx:id="tabSavings" text="Savings" onMouseClicked="#handleLedgerTab" styleClass="tab-lbl" />
                                <Label fx:id="tabDebt" text="Debt" onMouseClicked="#handleLedgerTab" styleClass="tab-lbl" />
                            </HBox>
                        </VBox>

                        <!-- FILTER BAR & SUBTITLE -->
                        <VBox spacing="12">
                            <HBox spacing="12" alignment="CENTER_LEFT">
                                <Button text="Date" onAction="#handleLedgerFilterDate" styleClass="btn-filter-pill" />
                                <Button text="Type" onAction="#handleLedgerFilterType" styleClass="btn-filter-pill" />
                                <Button text="Category" onAction="#handleLedgerFilterCategory" styleClass="btn-filter-pill" />
                                <Button text="Sender / Receiver" onAction="#handleLedgerFilterSender" styleClass="btn-filter-pill" />
                                <Button text="+ More Filters" onAction="#handleLedgerMoreFilters" styleClass="btn-filter-pill-action" />
                            </HBox>
                            <Label fx:id="ledgerShowingLabel" text="Showing 1-100 of 10,000" styleClass="card-subtitle" />
                        </VBox>

                        <!-- MAIN SPLIT LAYOUT -->
                        <HBox spacing="28" VBox.vgrow="ALWAYS">
                            <!-- LEFT: MAIN TABLE AREA -->
                            <VBox styleClass="card" HBox.hgrow="ALWAYS" spacing="16" style="-fx-padding: 24;">
                                <TableView fx:id="ledgerTable" prefHeight="650" style="-fx-padding: 4;" VBox.vgrow="ALWAYS">
                                    <columns>
                                        <TableColumn fx:id="ledgDateCol" prefWidth="150" text="DATE &amp; TIME" />
                                        <TableColumn fx:id="ledgTypeCol" prefWidth="120" text="ACTION" />
                                        <TableColumn fx:id="ledgCatCol" prefWidth="120" text="CATEGORY" />
                                        <TableColumn fx:id="ledgItemCol" prefWidth="180" text="DESCRIPTION" />
                                        <TableColumn fx:id="ledgSenderCol" prefWidth="220" text="SENDER / RECEIVER" />
                                        <TableColumn fx:id="ledgAmountCol" prefWidth="120" style="-fx-alignment: CENTER-RIGHT;" text="AMOUNT" />
                                    </columns>
                                    <columnResizePolicy><TableView fx:constant="CONSTRAINED_RESIZE_POLICY" /></columnResizePolicy>
                                </TableView>
                            </VBox>

                            <!-- RIGHT: INSPECT PANEL -->
                            <VBox spacing="20" prefWidth="380">
                                <!-- Status Card -->
                                <VBox styleClass="card" spacing="16" style="-fx-padding: 24;">
                                    <HBox alignment="CENTER_LEFT">
                                        <Label text="Transaction Status" styleClass="card-title" />
                                        <Region HBox.hgrow="ALWAYS" />
                                        <Button text="Edit Bill" onAction="#handleLedgerEditBill" styleClass="btn-link" />
                                    </HBox>
                                    <HBox alignment="CENTER_LEFT" spacing="12">
                                        <Circle radius="5" fill="#3b82f6" />
                                        <VBox spacing="2">
                                            <Label text="Waiting for approval" style="-fx-font-weight: 700; -fx-text-fill: #3b82f6;" />
                                            <Label text="By System Admin" styleClass="card-subtitle" />
                                        </VBox>
                                    </HBox>
                                    <Button text="See all statuses ⌄" onAction="#handleLedgerSeeStatuses" styleClass="btn-flat-wide" />
                                </VBox>

                                <!-- Audit Info Banner -->
                                <HBox styleClass="audit-banner" spacing="12" alignment="CENTER_LEFT">
                                    <Label text="i" styleClass="audit-icon" />
                                    <Label text="Please fill out all details for future audit purposes. See empty fields" styleClass="audit-text" wrapText="true" HBox.hgrow="ALWAYS" />
                                </HBox>

                                <!-- Transaction Details Section -->
                                <VBox styleClass="card" spacing="20" style="-fx-padding: 24;">
                                    <Label text="Transaction Details" styleClass="card-title" />
                                    <GridPane hgap="16" vgap="16">
                                        <Label text="Transaction Number" styleClass="detail-lbl" GridPane.columnIndex="0" GridPane.rowIndex="0" />
                                        <Label fx:id="detailIdLabel" text="1234567890abc1244" styleClass="detail-val, mono" GridPane.columnIndex="1" GridPane.rowIndex="0" GridPane.hgrow="ALWAYS" />
                                        
                                        <Label text="Created Date &amp; Time" styleClass="detail-lbl" GridPane.columnIndex="0" GridPane.rowIndex="1" />
                                        <Label fx:id="detailDateLabel" text="20 Jun 2020, 13:30" styleClass="detail-val" GridPane.columnIndex="1" GridPane.rowIndex="1" GridPane.hgrow="ALWAYS" />
                                        
                                        <Label text="Transaction Type" styleClass="detail-lbl" GridPane.columnIndex="0" GridPane.rowIndex="2" />
                                        <Label fx:id="detailTypeLabel" text="Bills" styleClass="detail-val" GridPane.columnIndex="1" GridPane.rowIndex="2" GridPane.hgrow="ALWAYS" />
                                        
                                        <Label text="FX Rate" styleClass="detail-lbl" GridPane.columnIndex="0" GridPane.rowIndex="3" />
                                        <Label text="1.00000000" styleClass="detail-val, mono" GridPane.columnIndex="1" GridPane.rowIndex="3" GridPane.hgrow="ALWAYS" />
                                    </GridPane>

                                    <VBox spacing="6">
                                        <Label text="Category" styleClass="detail-lbl-bold" />
                                        <ComboBox fx:id="detailCatCombo" promptText="Office Supplies" styleClass="combo-box-flat-wide" prefWidth="332" />
                                    </VBox>

                                    <VBox spacing="6">
                                        <Label text="Tax" styleClass="detail-lbl-bold" />
                                        <ComboBox promptText="Select tax" styleClass="combo-box-flat-wide" prefWidth="332" />
                                    </VBox>

                                    <VBox spacing="6">
                                        <Label text="Tags" styleClass="detail-lbl-bold" />
                                        <ComboBox promptText="Select tags" styleClass="combo-box-flat-wide" prefWidth="332" />
                                    </VBox>

                                    <Button text="Save Details" onAction="#handleSaveTransactionDetails" styleClass="btn-primary" prefWidth="332" />
                                </VBox>
                            </VBox>
                        </HBox>
                    </VBox>
                </content>
            </ScrollPane>

        </StackPane>
    </center>
</BorderPane>
